# URL of the vLLM Cloud Run GPU service /v1 endpoint
# e.g. https://my-vllm-service-xxxx-ue.a.run.app/v1
VLLM_BASE_URL=https://your-vllm-service-url/v1

# Model name as configured in Dockerfile.vllm (--served-model-name)
VLLM_MODEL_NAME=my-model

# Max prompt length accepted by the demo app (chars)
MAX_INPUT_CHARS=2000
